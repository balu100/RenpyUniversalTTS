{
  "enabled": true,
  "engine": "vibevoice",
  "speaker_name_mode": "on_speaker_change",
  "tools": {
    "curl_path": "curl",
    "ffplay_path": "ffplay",
    "ffplay_loglevel": "error",
    "ffplay_channel_option": "ch_layout",
    "ffplay_volume": null,
    "ffplay_extra_args": []
  },
  "audio": {
    "raw_pcm": true,
    "sample_format": "s16le",
    "sample_rate": 24000,
    "channel_layout": "mono"
  },
  "request": {
    "type": "openai"
  },
  "openai": {
    "url": "http://localhost:8880/v1/audio/speech",
    "model": "tts-1",
    "response_format": "pcm",
    "stream": true,
    "speed": null,
    "extra_body": {}
  },
  "default_voice": "Emma",
  "voices": {
    "Narrator": "Davis",
    "MC": "Mike",
    "Daniel": "Mike"
  }
}
